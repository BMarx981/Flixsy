<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Launch theme for Android 12+ (API 31), light mode. The system splash
         screen draws the launcher icon over windowSplashScreenBackground;
         windowBackground still covers the gap until Flutter's first frame. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/launch_background</item>
    </style>
</resources>
