require 'fileutils'

# Uncomment this line to define a global platform for your project
platform :ios, '14.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

def prune_connectsdk_lgcast!(installer)
  lgcast_markers = [
    'core/Services/Helpers/LGCast/',
    'WebOSTVService+LGCast.h',
    'WebOSTVService+LGCast.m',
    'RemoteCameraService.h',
    'RemoteCameraService.m',
    'ScreenMirroringService.h',
    'ScreenMirroringService.m',
    'CameraParameter.h',
    'CameraParameter.m',
    'CameraSinkCapability.h',
    'CameraSinkCapability.m',
    'CameraSourceCapability.h',
    'CameraSourceCapability.m',
    'MirroringSinkCapability.h',
    'MirroringSinkCapability.m',
    'MirroringSourceCapability.h',
    'MirroringSourceCapability.m',
    'ConnectionManager.h',
    'ConnectionManager.m',
    'MobileCapability.h',
    'MobileCapability.m',
  ]

  connectsdk_target = installer.pods_project.targets.find { |target| target.name == 'ConnectSDK' }
  return unless connectsdk_target

  [connectsdk_target.source_build_phase, connectsdk_target.headers_build_phase].each do |phase|
    phase.files.dup.each do |build_file|
      ref = build_file.file_ref
      next unless ref

      path = ref.path.to_s
      next unless lgcast_markers.any? { |marker| path.include?(marker) }

      phase.remove_build_file(build_file)
    end
  end

  webos_service_path = File.join(installer.sandbox.root.to_s, 'ConnectSDK/core/Services/WebOSTVService.m')
  if File.exist?(webos_service_path)
    FileUtils.chmod('u+w', webos_service_path)
    contents = File.read(webos_service_path)
    contents.gsub!("#import \"RemoteCameraService.h\"\n", '')
    contents.gsub!("#import \"ScreenMirroringService.h\"\n", '')
    contents.gsub!(
      '@interface WebOSTVService () <UIAlertViewDelegate, WebOSTVServiceSocketClientDelegate, RemoteCameraServiceDelegate, ScreenMirroringServiceDelegate>',
      '@interface WebOSTVService () <UIAlertViewDelegate, WebOSTVServiceSocketClientDelegate>'
    )
    contents.gsub!("    __weak id<RemoteCameraControlDelegate> _remoteCameraDelegate;\n", '')
    contents.gsub!("    __weak id<ScreenMirroringControlDelegate> _screenMirroringDelegate;\n", '')
    # Empty the closeByResponse: body — it referenced LG Cast delegate types.
    # Scan braces to find the matching close: the original body has nested
    # braces, and a /\{[^}]*\}/ regex stops at the first one, leaving a stray
    # closing brace behind. This is brace-balanced and idempotent.
    close_marker = '- (void) closeByResponse:(NSError *)error'
    if (method_start = contents.index(close_marker))
      brace_start = contents.index('{', method_start)
      if brace_start
        depth = 0
        index = brace_start
        while index < contents.length
          depth += 1 if contents[index] == '{'
          depth -= 1 if contents[index] == '}'
          break if depth.zero?
          index += 1
        end
        contents[method_start..index] = "#{close_marker}\n{\n}"
      end
    end
    contents.sub!(/\n#pragma mark - ScreenMirroringControl.*\n@end\s*\z/m, "\n@end\n")
    File.write(webos_service_path, contents)
  end

  umbrella_path = File.join(installer.sandbox.root.to_s, 'Target Support Files/ConnectSDK/ConnectSDK-umbrella.h')
  if File.exist?(umbrella_path)
    FileUtils.chmod('u+w', umbrella_path)
    contents = File.read(umbrella_path)
    contents = contents.lines.reject do |line|
      lgcast_markers.any? { |marker| line.include?(%("#{File.basename(marker)}")) }
    end.join
    File.write(umbrella_path, contents)
  end
end

# Companion to prune_connectsdk_lgcast!: the source files are gone, but CocoaPods
# still links/embeds the LG Cast xcframeworks. They ship only ios-arm64 (device)
# and ios-x86_64-simulator slices — no arm64 simulator slice — so an Apple Silicon
# simulator build fails with "Framework 'GStreamerForLGCast' not found".
# Strip the dead linkage and embed steps from the generated support files.
def prune_connectsdk_lgcast_frameworks!(installer)
  lgcast_frameworks = ['GStreamerForLGCast', 'LGCast']
  support_files_root = File.join(installer.sandbox.root.to_s, 'Target Support Files')

  # Remove -framework flags from every generated xcconfig.
  Dir.glob(File.join(support_files_root, '**', '*.xcconfig')).each do |xcconfig|
    contents = File.read(xcconfig)
    updated = contents.dup
    lgcast_frameworks.each do |fw|
      updated.gsub!(/\s*-framework\s+"#{fw}"/, '')
    end
    next if updated == contents

    FileUtils.chmod('u+w', xcconfig)
    File.write(xcconfig, updated)
  end

  # Remove the embed (install_framework) calls and file-list entries.
  Dir.glob(File.join(support_files_root, '**', '*frameworks*.{sh,xcfilelist}')).each do |file|
    contents = File.read(file)
    updated = contents.lines.reject do |line|
      lgcast_frameworks.any? { |fw| line.include?("#{fw}.framework") }
    end.join
    next if updated == contents

    FileUtils.chmod('u+w', file)
    File.write(file, updated)
  end
end

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  pod 'ConnectSDK',
    :podspec => 'https://raw.githubusercontent.com/ConnectSDK/Connect-SDK-iOS/master/ConnectSDK.podspec',
    :subspecs => ['Core']
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  prune_connectsdk_lgcast!(installer)
  prune_connectsdk_lgcast_frameworks!(installer)
end
